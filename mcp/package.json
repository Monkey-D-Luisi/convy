    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-singlefile": "2.3.3"
  }
