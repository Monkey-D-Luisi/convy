    "body": [
      "data class ${1:Screen}State(",
      "    val ${2:items}: List<${3:Item}> = emptyList(),",
      "    val isLoading: Boolean = false,",
      "    val error: String? = null,",
      "    $0",
      ")"
    ]
  },
