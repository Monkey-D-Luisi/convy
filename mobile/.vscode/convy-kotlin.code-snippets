    "prefix": "mvi-intent",
    "scope": "kotlin",
    "description": "MVI Intent sealed interface with sample actions",
    "body": [
      "sealed interface ${1:Screen}Intent {",
      "    data object Refresh : ${1}Intent",
      "    data object NavigateBack : ${1}Intent",
