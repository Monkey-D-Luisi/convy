{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/layer-guard.ps1",
        "timeout": 10
      }
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${CONVY_DEV_DATABASE_URL}"
      ]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
