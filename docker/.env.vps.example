POSTGRES_DB=convy
POSTGRES_USER=convy
POSTGRES_PASSWORD=replace-with-strong-password

CONVY_API_HOSTNAME=api.convy.app
CONVY_ADMIN_HOSTNAME=admin.convy.app
CONVY_LEGAL_HOSTNAME=legal.convy.app
FIREBASE_PROJECT_ID=convy-6520d
FIREBASE_WEB_API_KEY=replace-with-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=convy-6520d.firebaseapp.com
FIREBASE_WEB_APP_ID=replace-with-firebase-web-app-id
OPENAI_API_KEY=sk-proj-replace
DATABASE_MIGRATE_ON_STARTUP=true
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_HASH=replace-with-caddy-hash
Admin__AllowedEmails=luis@example.com

OpenAI__TranscriptionModel=gpt-4o-mini-transcribe
OpenAI__ParsingModel=gpt-5.4-nano
OpenAI__Costs__TranscriptionAudioInputMicrosPerSecond=
OpenAI__Costs__ParsingInputMicrosPer1KTokens=
OpenAI__Costs__ParsingCachedInputMicrosPer1KTokens=
OpenAI__Costs__ParsingOutputMicrosPer1KTokens=
OpenAI__Costs__ParsingReasoningMicrosPer1KTokens=
Operations__BackupRoot=/opt/convy/backups/postgres
PushNotifications__BatchWindowSeconds=60

