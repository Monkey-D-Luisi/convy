root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{json,xml,csproj,props,targets}]
indent_size = 2

[*.{kt,kts}]
indent_size = 4

[*.{gradle,gradle.kts}]
indent_size = 4

[*.toml]
indent_size = 4

[Dockerfile*]
indent_size = 4
